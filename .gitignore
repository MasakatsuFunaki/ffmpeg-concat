# Ignore everything
*

# Allow top-level files
!README.md
!LICENSE
!CMakeLists.txt
!CMakeUserPresets.json
!release.py



# Allow build/Release/ only
!build/
build/*
!build/Release/
build/Release/**

# Exclude test executables from Release
build/Release/test*.exe

# Allow ffmpeg binary parts (split for GitHub <100MB limit)
!bin/
bin/*
!bin/ffmpeg.part*

# Allow input/output folders (keep them as empty dirs via .gitkeep)
!input/
input/*
!input/.gitkeep
!output/
output/*
!output/.gitkeep

# Keep .gitignore itself
!.gitignore
!.gitattributes
CMakeUserPresets.json

# Allow GitHub Actions workflows
!.github/
!.github/workflows/
!.github/workflows/*.yml
